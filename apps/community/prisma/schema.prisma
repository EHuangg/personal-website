generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id                    String    @id @default(cuid())
  prompt                String
  fingerprintHash       String
  displayName           String?
  status                Status    @default(PENDING)
  autoRejectionReason   String?
  manualRejectionReason String?
  moderatedAt           DateTime?
  createdAt             DateTime  @default(now())

  build        Build?
  fingerprints Fingerprint[]

  @@index([fingerprintHash])
  @@index([status])
  @@index([createdAt])
}

model Build {
  id             String      @id @default(cuid())
  submissionId   String      @unique
  generatedPatch Json
  status         BuildStatus @default(SUCCESS)
  errorMessage   String?
  builtAt        DateTime    @default(now())

  submission   Submission    @relation(fields: [submissionId], references: [id])
  snapshots    SiteSnapshot[]
}

model SiteSnapshot {
  id                  String   @id @default(cuid())
  buildId             String?
  htmlContent         String
  authorDisplayName   String?
  authorFingerprint   String
  isCurrent           Boolean  @default(false)
  isDefault           Boolean  @default(false)
  createdAt           DateTime @default(now())

  build Build? @relation(fields: [buildId], references: [id])

  @@index([isCurrent])
  @@index([createdAt])
}

model Fingerprint {
  id              String   @id @default(cuid())
  fingerprintHash String
  submissionId    String
  createdAt       DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([fingerprintHash])
  @@index([createdAt])
}

enum Status {
  PENDING
  AUTO_REJECTED
  MANUALLY_REJECTED
  QUEUED
  BUILT
  SKIPPED
}

enum BuildStatus {
  SUCCESS
  FAILED
}
